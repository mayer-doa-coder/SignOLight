# ===========================
# SignLearn Backend Config
# ===========================

# Your Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=gsk_your-key-here

# Free-plan friendly default for fast caption glossing
GROQ_MODEL=llama-3.1-8b-instant

# Number of captions translated per Groq request
GROQ_BATCH_SIZE=10

# Frontend URL for CORS (your Vercel/Netlify URL)
FRONTEND_URL=http://localhost:3000

# Port (Render sets this automatically)
PORT=5000
